# ── auth-стек (Keycloak + oauth2-proxy) — скопировать в .env на третьей машине ──

# WG-адрес ЭТОЙ (третьей) машины — на него Traefik(VDS) ходит за oauth2-proxy/keycloak.
# Порты публикуются только сюда (не 0.0.0.0).
BIND_IP=10.10.0.XXX

# ── Keycloak ──
KC_HOSTNAME=login.victory62.org        # публичный хост Keycloak (через Traefik VDS)
KC_REALM=media                          # realm, который создадите в Keycloak
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=                       # задайте надёжный; смените после первого входа
KC_DB_PASSWORD=                          # openssl rand -hex 16

# ── oauth2-proxy ↔ Keycloak (client из realm `media`) ──
OAUTH2_CLIENT_ID=media-proxy
OAUTH2_CLIENT_SECRET=                     # из Keycloak: client `media-proxy` → Credentials
OAUTH2_COOKIE_SECRET=                     # openssl rand -base64 32  (ровно 32 байта)
