# ── auth-стек (Keycloak + oauth2-proxy) — для mgmt-eu (Phase 1) ──
# Скопировать в .env (gitignored). На CI прод-.env генерируется из GitHub Secrets.

# Где публикуем порты Keycloak/oauth2-proxy.
#   - 0.0.0.0           = слушаем на всех интерфейсах (edge=caddy/traefik/CF Tunnel на той же VPS)
#   - 10.X.X.X (NetBird)= после Phase 2 — доступ только через overlay-фабрику
#   - 127.0.0.1         = если edge — sidecar на том же host network (например cloudflared)
BIND_IP=0.0.0.0

# ── Keycloak (Phase 1: один inst на mgmt-eu; Phase 6: + replica на cdn) ──
KC_HOSTNAME_URL=https://login.example.com   # полный URL для issuer-claim (KC_HOSTNAME env-var в compose)
KC_PUBLIC_HOST=login.example.com            # short host для traefik/edge маршрутизации
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=                          # openssl rand -base64 24
KC_DB_PASSWORD=                             # openssl rand -hex 16

# Realm bootstrap из ./realms/*.json (--import-realm, idempotent):
#   - factory-admin  (NetBird/Proxmox/Grafana/forward-auth-admin; 2FA WebAuthn обязательно)
#   - family         (Jellyfin/Seerr/Nextcloud; 2FA опционально)
# После первого старта: задать реальные client-secrets в UI → экспортировать realm обратно
# (kc.sh export --dir /opt/keycloak/data/export --realm <name>) → положить в ./realms/

# ── oauth2-proxy (forward-auth для admin-сервисов через realm factory-admin) ──
OIDC_ISSUER_URL=https://login.example.com/realms/factory-admin
OAUTH2_CLIENT_ID=forward-auth-admin
OAUTH2_CLIENT_SECRET=                       # из KC realm factory-admin / client forward-auth-admin / Credentials
OAUTH2_COOKIE_SECRET=                       # openssl rand -hex 16 (ровно 32 hex символа)
COOKIE_DOMAIN=.example.com                  # домен auth-cookie (все *.example.com)

# Группы из OIDC claim `groups`, которым разрешён доступ к admin-сервисам:
OAUTH2_ALLOWED_GROUPS=netadmins,office-staff,home-power-users

# ── Информационно (для документации; в этом compose не используются) ──
# NetBird Management UI:  https://nb.example.com  (Phase 2)
# Grafana:                https://grafana.example.com  (Phase 8)
# Family-realm KC issuer: https://login.example.com/realms/family
