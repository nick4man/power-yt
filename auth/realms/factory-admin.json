{
  "realm": "factory-admin",
  "displayName": "Factory Admin",
  "displayNameHtml": "<strong>Factory</strong> Admin",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "failureFactor": 5,
  "waitIncrementSeconds": 60,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "accessTokenLifespan": 600,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "passwordPolicy": "length(12) and notUsername and notEmail and specialChars(1) and digits(1) and upperCase(1)",
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyLookAheadWindow": 1,
  "otpPolicyPeriod": 30,
  "webAuthnPolicyRpEntityName": "Factory Admin",
  "webAuthnPolicyRpId": "",
  "webAuthnPolicySignatureAlgorithms": ["ES256", "RS256"],
  "webAuthnPolicyAttestationConveyancePreference": "not specified",
  "webAuthnPolicyAuthenticatorAttachment": "not specified",
  "webAuthnPolicyRequireResidentKey": "not specified",
  "webAuthnPolicyUserVerificationRequirement": "preferred",
  "requiredActions": [
    { "alias": "CONFIGURE_TOTP", "name": "Configure OTP", "providerId": "CONFIGURE_TOTP", "enabled": true, "defaultAction": false, "priority": 10, "config": {} },
    { "alias": "TERMS_AND_CONDITIONS", "name": "Terms and Conditions", "providerId": "TERMS_AND_CONDITIONS", "enabled": false, "defaultAction": false, "priority": 20, "config": {} },
    { "alias": "UPDATE_PASSWORD", "name": "Update Password", "providerId": "UPDATE_PASSWORD", "enabled": true, "defaultAction": false, "priority": 30, "config": {} },
    { "alias": "UPDATE_PROFILE", "name": "Update Profile", "providerId": "UPDATE_PROFILE", "enabled": true, "defaultAction": false, "priority": 40, "config": {} },
    { "alias": "VERIFY_EMAIL", "name": "Verify Email", "providerId": "VERIFY_EMAIL", "enabled": true, "defaultAction": false, "priority": 50, "config": {} },
    { "alias": "delete_account", "name": "Delete Account", "providerId": "delete_account", "enabled": false, "defaultAction": false, "priority": 60, "config": {} },
    { "alias": "webauthn-register", "name": "Webauthn Register", "providerId": "webauthn-register", "enabled": true, "defaultAction": false, "priority": 70, "config": {} },
    { "alias": "update_user_locale", "name": "Update User Locale", "providerId": "update_user_locale", "enabled": true, "defaultAction": false, "priority": 1000, "config": {} }
  ],
  "groups": [
    { "name": "netadmins", "attributes": {}, "realmRoles": ["factory-admin"], "clientRoles": {} },
    { "name": "office-staff", "attributes": {}, "realmRoles": ["operator"], "clientRoles": {} },
    { "name": "home-power-users", "attributes": {}, "realmRoles": ["site-admin"], "clientRoles": {} }
  ],
  "roles": {
    "realm": [
      { "name": "factory-admin", "description": "Полный admin фабрики (все сайты, все policy)", "composite": false },
      { "name": "site-admin", "description": "Admin одного сайта/гейтвея", "composite": false },
      { "name": "operator", "description": "Read + restart сервисов, без правки топологии", "composite": false }
    ]
  },
  "clients": [
    {
      "clientId": "netbird",
      "name": "NetBird Management",
      "description": "OIDC IdP для NetBird: PKCE flow (dashboard) + device-flow (CLI `netbird up`)",
      "enabled": true,
      "publicClient": true,
      "clientAuthenticatorType": "client-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": ["https://nb.example.com/*", "http://localhost:53000"],
      "webOrigins": ["https://nb.example.com", "+"],
      "attributes": {
        "post.logout.redirect.uris": "https://nb.example.com/+",
        "access.token.lifespan": "3600",
        "oauth2.device.authorization.grant.enabled": "true",
        "oidc.ciba.grant.enabled": "false",
        "pkce.code.challenge.method": "S256"
      },
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "netbird-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "netbird",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "forward-auth-admin",
      "name": "Traefik forward-auth (admin services)",
      "description": "Защита админок медиа-стека: sonarr/radarr/prowlarr/bazarr/qbit/cleanuparr/jellystat/tdarr",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "REPLACE-AFTER-FIRST-LOGIN-IN-UI",
      "standardFlowEnabled": true,
      "redirectUris": ["https://media.example.com/oauth2/callback", "https://*.media.example.com/oauth2/callback"],
      "webOrigins": ["https://media.example.com"],
      "attributes": {
        "post.logout.redirect.uris": "https://media.example.com/+",
        "access.token.lifespan": "3600"
      },
      "protocol": "openid-connect"
    },
    {
      "clientId": "proxmox-msk",
      "name": "Proxmox-1 (Moscow office)",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "REPLACE-AFTER-FIRST-LOGIN-IN-UI",
      "standardFlowEnabled": true,
      "redirectUris": ["https://proxmox-msk.example.com/"],
      "webOrigins": ["https://proxmox-msk.example.com"],
      "protocol": "openid-connect"
    },
    {
      "clientId": "proxmox-rzn",
      "name": "Proxmox-2 (Ryazan home)",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "REPLACE-AFTER-FIRST-LOGIN-IN-UI",
      "standardFlowEnabled": true,
      "redirectUris": ["https://proxmox-rzn.example.com/"],
      "webOrigins": ["https://proxmox-rzn.example.com"],
      "protocol": "openid-connect"
    },
    {
      "clientId": "grafana",
      "name": "Grafana (factory observability)",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "REPLACE-AFTER-FIRST-LOGIN-IN-UI",
      "standardFlowEnabled": true,
      "redirectUris": ["https://grafana.example.com/login/generic_oauth"],
      "webOrigins": ["https://grafana.example.com"],
      "protocol": "openid-connect"
    }
  ],
  "smtpServer": {},
  "eventsEnabled": true,
  "eventsExpiration": 2592000,
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": false,
  "internationalizationEnabled": true,
  "supportedLocales": ["en", "ru"],
  "defaultLocale": "en"
}
