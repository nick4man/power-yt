# ─────────────────────────────────────────────────────────────
#  media-stack — переменные окружения
#  Скопируйте в .env (он в .gitignore) и поправьте под себя.
# ─────────────────────────────────────────────────────────────

# ── Идентичность и права ──
# PUID=1000 — пользователь q, владелец данных на NAS (ключевой для доступа через NFSv4 ACL).
PUID=1000
PGID=3000            # gid медиа-группы (правами на NAS рулит ACL, gid вторичен)
UMASK=002            # новые файлы 664 / каталоги 775 — группа имеет запись
TZ=Europe/Moscow

# ── Хранилище ──
# Общий /data = NFS-датасет TrueNAS (192.168.0.12:/mnt/media/data),
# монтирует systemd/mnt-storage-data.mount. ВСЕ сервисы биндят только это.
DATA_ROOT=/mnt/storage/data

# ── Сеть / публикация портов ──
# IP интерфейса WireGuard (или LAN), на который публикуем порты. НЕ ставьте 0.0.0.0!
# Удалённый Traefik (VDS) ходит на BIND_IP:порт через WG-туннель.
BIND_IP=10.10.0.189
JELLYFIN_PORT=8096
SONARR_PORT=8989
RADARR_PORT=7878
PROWLARR_PORT=9696
BAZARR_PORT=6767
QBIT_WEBUI_PORT=8080
QBIT_BT_PORT=6881          # входящий torrent-порт (tcp+udp), публикуется наружу
JELLYSEERR_PORT=5055

# ── Образы (channel hotio: release|latest|nightly; для воспроизводимости лучше пиннить версию) ──
JELLYFIN_IMAGE=ghcr.io/hotio/jellyfin:release
SONARR_IMAGE=ghcr.io/hotio/sonarr:release
RADARR_IMAGE=ghcr.io/hotio/radarr:release
PROWLARR_IMAGE=ghcr.io/hotio/prowlarr:release
BAZARR_IMAGE=ghcr.io/hotio/bazarr:release
QBIT_IMAGE=ghcr.io/hotio/qbittorrent:release
JELLYSEERR_IMAGE=docker.io/seerr/seerr:latest

# ── Внешний адрес (информационно; маршрутизация на Traefik VDS) ──
JELLYFIN_PUBLISHED_URL=https://jellyfin.sodix.org

# ── Доп. arr: Lidarr (музыка) + Whisparr (xxx) ──
LIDARR_PORT=8686
WHISPARR_PORT=6969
LIDARR_IMAGE=ghcr.io/hotio/lidarr:release
WHISPARR_IMAGE=ghcr.io/hotio/whisparr:latest

# ── Сопутствующие сервисы ──
RECYCLARR_IMAGE=ghcr.io/recyclarr/recyclarr:latest
UNPACKERR_IMAGE=golift/unpackerr:latest
CLEANUPARR_IMAGE=ghcr.io/cleanuparr/cleanuparr:latest
CLEANUPARR_PORT=11011
JELLYSTAT_IMAGE=docker.io/cyfershepard/jellystat:latest
JELLYSTAT_DB_IMAGE=docker.io/postgres:16-alpine
JELLYSTAT_PORT=3000
JELLYSTAT_PG_PASSWORD=changeme
JELLYSTAT_JWT=changeme-long-random
TDARR_IMAGE=ghcr.io/haveagitgat/tdarr:latest
TDARR_WEBUI_PORT=8265
TDARR_SERVER_PORT=8266

# ── API-ключи arr (для unpackerr/recyclarr) — взять из <svc>/config/config.xml ──
SONARR_API_KEY=
RADARR_API_KEY=
LIDARR_API_KEY=
WHISPARR_API_KEY=
FLARESOLVERR_IMAGE=ghcr.io/flaresolverr/flaresolverr:latest
