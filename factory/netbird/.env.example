# ── NetBird MGMT combined (factory/netbird, v0.71+) — для mgmt-eu (Phase 2) ──
# Скопировать в .env (gitignored). На CI генерируется из GitHub Secrets.

# Корень доменов фабрики. Хосты: nb.${FABRIC_DOMAIN} (NetBird), login.${FABRIC_DOMAIN} (Keycloak).
FABRIC_DOMAIN=example.com

# Публичный IPv4 mgmt-eu — для STUN external-ip (NAT-aware). Прописывается в exposedAddress.
MGMT_PUBLIC_IP=192.0.2.1

# Секреты — генерировать локально: openssl rand -base64 32
#   NETBIRD_RELAY_AUTH_SECRET — авторизация нативного relay (server.authSecret)
#   DATASTORE_ENCRYPTION_KEY  — шифрование sqlite-store (PII peers/setup-keys)
NETBIRD_RELAY_AUTH_SECRET=
DATASTORE_ENCRYPTION_KEY=

# Образы — пин под совместимость server↔dashboard (НЕ :latest на проде).
# Версию dashboard под server 0.71.4 свериться в release-notes; latest — fallback.
NETBIRD_SERVER_IMAGE=netbirdio/netbird-server:0.71.4
NETBIRD_DASHBOARD_IMAGE=netbirdio/dashboard:latest

# ── Auth-модель: ВНЕШНИЙ Keycloak (realm factory-admin), публичный client `netbird` ──
# client_secret НЕ нужен (publicClient: PKCE + device-flow). Встроенный Dex НЕ используется.
# Если когда-нибудь захочешь Dex-федерацию или IdP-sync — это отдельная задача.
