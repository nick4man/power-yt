# ── NetBird MGMT (factory/netbird) — для mgmt-eu (Phase 2) ──
# Скопировать в .env (gitignored). На CI генерируется из GitHub Secrets.

# Корень доменов фабрики. Подсадные хосты:
#   nb.${FABRIC_DOMAIN}     — NetBird management API + dashboard
#   login.${FABRIC_DOMAIN}  — Keycloak (Phase 1)
FABRIC_DOMAIN=example.com

# Публичный IPv4 mgmt-eu — нужен Coturn для external-ip (NAT-aware STUN/TURN).
MGMT_PUBLIC_IP=192.0.2.1

# TURN секреты — генерировать локально: openssl rand -hex 32
# Эти же значения вписать в:
#   management.json → TURNConfig.Secret + Turns[0].Password
#   turnserver.conf → user=netbird:<TURN_PASSWORD>
TURN_SHARED_SECRET=
TURN_PASSWORD=

# (опц.) Если хочешь NetBird сам управлять пользователями в KC (создавать/удалять):
#   - создать в realm factory-admin клиента netbird-backend с client_credentials grant
#   - дать ему service-account роль realm-management/manage-users
#   - сюда положить его secret + в management.json IdpManagerConfig.ManagerType=keycloak
NB_IDP_CLIENT_ID=netbird-backend
NB_IDP_CLIENT_SECRET=
