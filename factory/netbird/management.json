        "https://nb.example.com/peers"
      ],
      "AuthorizationEndpoint": "https://login.example.com/realms/factory-admin/protocol/openid-connect/auth",
      "TokenEndpoint": "https://login.example.com/realms/factory-admin/protocol/openid-connect/token",
