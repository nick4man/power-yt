# ── Phase 8: observability stack (mgmt-eu) ──

# Publish порты — по умолчанию 127.0.0.1 (доступ через edge на той же VPS).
# Для доступа из NetBird overlay: 10.50.0.1 (mgmt-eu admin VNI loopback).
BIND_IP=127.0.0.1

# Grafana root URL — для OIDC redirect URI и провижионинга
GF_ROOT_URL=https://grafana.example.com
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=                             # openssl rand -base64 24

# Alertmanager → Telegram (см. https://core.telegram.org/bots)
# 1. @BotFather → /newbot → получить bot_token
# 2. Добавить бота в канал/группу для алёртов
# 3. curl https://api.telegram.org/bot${TG_BOT_TOKEN}/getUpdates → chat_id
TG_BOT_TOKEN=                                  # 1234567890:ABC...
TG_CHAT_ID=                                    # -1001234567890 (для группы — отрицательный)
