# ── Edge-Traefik (factory/edge) — Phase 1.5 ──
# Скопировать в .env (gitignored), заполнить, затем ./render.sh && docker compose up -d

# Корень доменов фабрики. Хосты: login.<dom>, nb.<dom>, grafana.<dom>
FABRIC_DOMAIN=example.com

# Email для Let's Encrypt (уведомления об истечении сертификата)
ACME_EMAIL=admin@example.com

# Cloudflare API token для DNS-01 challenge.
# Создать: Cloudflare dashboard → My Profile → API Tokens → Create Token
#   Permissions: Zone : DNS : Edit  +  Zone : Zone : Read
#   Zone Resources: Include → Specific zone → <ваш-домен>
# Токен НЕ коммитить — только здесь, в .env (gitignored).
CF_DNS_API_TOKEN=
