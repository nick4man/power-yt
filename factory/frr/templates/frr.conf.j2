! ═══════════════════════════════════════════════════════════════════════
!  FRRouting конфиг для peer'а фабрики (Phase 4 — iBGP + EVPN).
!  Генерируется Ansible-template из inventory + group_vars/all.yml.
!  Правки руками будут стёрты следующим прогоном playbook'а.
!
!  Address-families:
!    - ipv4 unicast    : underlay reachability (loopbacks, local LANs, default)
!    - l2vpn evpn      : overlay membership (VNI MAC/IP routes type-2/3)
!
!  Site-gw / exit / member peer'ятся ТОЛЬКО к RR — full-mesh не нужен.
!  RR-узлы делают route-reflection для всех остальных + сами VTEP-able
!  (если announced_vnis непуст).
! ═══════════════════════════════════════════════════════════════════════
frr version 8.4
frr defaults traditional
hostname {{ inventory_hostname }}
no ipv6 forwarding
log syslog informational
service integrated-vtysh-config
!
{% if fabric_role in ['rr-primary', 'rr-backup'] %}
! ─── Этот узел — Route-Reflector ────────────────────────────────────────
router bgp {{ fabric_as }}
 bgp router-id {{ fabric_loopback }}
 bgp cluster-id {{ fabric_loopback }}
 no bgp default ipv4-unicast
 no bgp ebgp-requires-policy
{% for h in groups['all'] | reject('match', inventory_hostname) %}
{% if hostvars[h].fabric_loopback is defined %}
 neighbor {{ hostvars[h].fabric_loopback }} remote-as {{ fabric_as }}
 neighbor {{ hostvars[h].fabric_loopback }} update-source lo
 neighbor {{ hostvars[h].fabric_loopback }} description {{ h }}
{% endif %}
{% endfor %}
 !
 address-family ipv4 unicast
{% for h in groups['all'] | reject('match', inventory_hostname) %}
{% if hostvars[h].fabric_loopback is defined %}
  neighbor {{ hostvars[h].fabric_loopback }} activate
  neighbor {{ hostvars[h].fabric_loopback }} route-reflector-client
{% endif %}
{% endfor %}
  network {{ fabric_loopback }}/32
 exit-address-family
 !
 address-family l2vpn evpn
{% for h in groups['all'] | reject('match', inventory_hostname) %}
{% if hostvars[h].fabric_loopback is defined %}
  neighbor {{ hostvars[h].fabric_loopback }} activate
  neighbor {{ hostvars[h].fabric_loopback }} route-reflector-client
{% endif %}
{% endfor %}
{% if announced_vnis is defined and announced_vnis | length > 0 %}
  advertise-all-vni
  advertise-default-gw
  advertise-svi-ip
{% endif %}
 exit-address-family
exit
{% else %}
! ─── Этот узел — site-gw / exit / member (НЕ route-reflector) ──────────
router bgp {{ fabric_as }}
 bgp router-id {{ fabric_loopback }}
 no bgp default ipv4-unicast
 no bgp ebgp-requires-policy
{% for rr in rr_peers %}
 neighbor {{ rr.loopback }} remote-as {{ fabric_as }}
 neighbor {{ rr.loopback }} update-source lo
 neighbor {{ rr.loopback }} description {{ rr.name }}-{{ rr.role }}
{% endfor %}
 !
 address-family ipv4 unicast
{% for rr in rr_peers %}
  neighbor {{ rr.loopback }} activate
{% endfor %}
  network {{ fabric_loopback }}/32
{% if local_lan_subnet is defined %}
  network {{ local_lan_subnet }}                      ! site-LAN, анонсируется в фабрику
{% endif %}
{% if fabric_role == 'exit' %}
  network 0.0.0.0/0                                   ! default-route, anti-censorship exit
{% endif %}
 exit-address-family
 !
 address-family l2vpn evpn
{% for rr in rr_peers %}
  neighbor {{ rr.loopback }} activate
{% endfor %}
{% if announced_vnis is defined and announced_vnis | length > 0 %}
  advertise-all-vni
{% if fabric_role == 'site-gw' %}
  advertise-default-gw
  advertise-svi-ip
{% endif %}
{% endif %}
 exit-address-family
exit
{% endif %}
!
line vty
!
end
