extends: default

rules:
  line-length:
    max: 200
    level: warning
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable
  document-start: disable
  truthy:
    check-keys: false
  indentation:
    indent-sequences: consistent
  braces:
    max-spaces-inside: 1

ignore: |
  factory/ansible/.fact_cache/
  factory/terraform/.terraform/
  factory/terraform/*.tfstate*
  factory/replica/data/
