# ── Phase 6: cdn standby replica для Keycloak ──
# Скопировать в .env (gitignored). На CI генерируется из GitHub Secrets.

# IP/hostname primary postgres (mgmt-eu) — должен быть достижим через overlay-фабрику
PG_PRIMARY_HOST=mgmt-eu-1.netbird.fabric       # MagicDNS NetBird
# либо: PG_PRIMARY_HOST=10.40.0.1                # overlay-loopback mgmt-eu
PG_PRIMARY_PORT=5432

# Пароль replication-user — ДОЛЖЕН совпадать с PG_REPLICATION_PASSWORD на mgmt-eu
PG_REPLICATION_PASSWORD=                       # тот же openssl rand -hex 32, что и на mgmt-eu

# Пароль application-user keycloak (на standby используется после promote)
KC_DB_PASSWORD=                                # тот же что на mgmt-eu (реплицируется в db)

# Хост (для failover) — тот же что на mgmt-eu (одинаковый KC_HOSTNAME для cookie/issuer consistency)
KC_HOSTNAME_URL=https://login.example.com

# Куда публикуем pg-standby. По дефолту 127.0.0.1 (доступ только локально).
# Если нужен внешний — поставь WG-IP cdn:
BIND_IP=127.0.0.1
