# ── Секреты и локальная конфигурация ──
.env
rclone/*.conf
!rclone/*.conf.example
**/secrets/

# ── Runtime-конфиги сервисов (содержимое, структуру оставляем через .gitkeep) ──
jellyfin/config/
jellyfin/cache/
jellyfin/transcode/
jellyfin/data/
sonarr/config/
radarr/config/
prowlarr/config/
bazarr/config/
qbittorrent/config/
jellyseerr/config/

# ── Прочее ──
*.log
*.pid
*.bak
.qbit-credentials
lidarr/config/
whisparr/config/
recyclarr/config/
cleanuparr/config/
jellystat/
tdarr/
auth/data/
auth/.env

# ── Overlay-фабрика (factory/): runtime, секреты, локальные TURN-credentials ──
factory/**/.env
factory/**/data/
factory/**/secrets/
factory/ansible/host_vars/*.local.yml
factory/terraform/*.tfvars
factory/terraform/.terraform/
factory/terraform/terraform.tfstate*
# edge: rendered dynamic config (содержит реальный домен) + ACME cert storage
factory/edge/dynamic/
factory/edge/acme/
# netbird: отрендеренные config.yaml/dashboard.env (реальный домен + relay/store секреты)
factory/netbird/config.yaml
factory/netbird/dashboard.env
factory/dns/*.tfvars
factory/dns/.terraform/
factory/dns/terraform.tfstate*
